rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    // ╔══════════════════════════════════════════════════════════════╗
    // ║  FUNÇÕES AUXILIARES                                         ║
    // ╚══════════════════════════════════════════════════════════════╝

    // Retorna o documento do usuário autenticado
    function getUserData() {
      return get(/databases/$(database)/documents/usuarios/$(request.auth.uid)).data;
    }

    // Verifica se está autenticado
    function isAuthenticated() {
      return request.auth != null;
    }

    // Verifica se o usuário está ativo e não bloqueado
    function isActiveUser() {
      let user = getUserData();
      return user.ativo == true && user.bloqueado == false;
    }

    // Retorna a role do usuário autenticado
    function getRole() {
      return getUserData().role;
    }

    // Verifica se é master
    function isMaster() {
      return isAuthenticated() && getRole() == 'master';
    }

    // Verifica se é administrador ou superior
    function isAdminOrAbove() {
      return isAuthenticated() && (getRole() == 'master' || getRole() == 'administrador');
    }

    // Verifica se é supervisor ou superior
    function isSupervisorOrAbove() {
      return isAuthenticated() && (getRole() == 'master' || getRole() == 'administrador' || getRole() == 'supervisor');
    }

    // Verifica se o admin é dono do condomínio (criou ele)
    function isCondominioOwner(condominioId) {
      let condo = get(/databases/$(database)/documents/condominios/$(condominioId)).data;
      let user = getUserData();
      return user.role == 'master' || condo.criadoPor == request.auth.uid;
    }

    // Verifica se o usuário tem acesso ao condomínio via cadeia hierárquica
    function hasCondominioAccess(condominioId) {
      let user = getUserData();
      // Master acessa tudo
      if (user.role == 'master') { return true; }
      // Administrador: só condominios que ele criou
      if (user.role == 'administrador') {
        let condo = get(/databases/$(database)/documents/condominios/$(condominioId)).data;
        return condo.criadoPor == request.auth.uid;
      }
      // Supervisor: condominios delegados pelo seu administrador
      if (user.role == 'supervisor') {
        return user.condominioId == condominioId;
      }
      // Funcionário: só o condomínio ao qual foi atribuído
      if (user.role == 'funcionario') {
        return user.condominioId == condominioId;
      }
      return false;
    }

    // Verifica se o usuário está na cadeia hierárquica de outro usuário
    function isInHierarchyOf(targetUserId) {
      let user = getUserData();
      let target = get(/databases/$(database)/documents/usuarios/$(targetUserId)).data;
      // Master vê todos
      if (user.role == 'master') { return true; }
      // Admin vê quem tem administradorId == seu id
      if (user.role == 'administrador') {
        return target.administradorId == request.auth.uid;
      }
      // Supervisor vê quem tem supervisorId == seu id
      if (user.role == 'supervisor') {
        return target.supervisorId == request.auth.uid;
      }
      return false;
    }

    // ╔══════════════════════════════════════════════════════════════╗
    // ║  COLLECTION: usuarios                                       ║
    // ╚══════════════════════════════════════════════════════════════╝

    match /usuarios/{userId} {
      // Ler: próprio perfil OU na cadeia hierárquica
      allow read: if isAuthenticated() && isActiveUser() && (
        request.auth.uid == userId ||
        isMaster() ||
        isInHierarchyOf(userId)
      );

      // Criar: só admin+ pode criar usuários, e deve marcar criadoPor com seu uid
      allow create: if isAuthenticated() && isActiveUser() && isAdminOrAbove() &&
        request.resource.data.criadoPor == request.auth.uid &&
        request.resource.data.ativo == true &&
        request.resource.data.bloqueado == false &&
        request.resource.data.email is string &&
        request.resource.data.nome is string &&
        request.resource.data.role in ['administrador', 'supervisor', 'funcionario'] &&
        // Admin não pode criar master nem outro admin (só master cria admin)
        (getRole() == 'master' || request.resource.data.role != 'administrador');

      // Atualizar próprio perfil (campos limitados)
      allow update: if isAuthenticated() && isActiveUser() && request.auth.uid == userId &&
        // Não pode mudar role, criadoPor, administradorId, bloqueado, ativo
        !request.resource.data.diff(resource.data).affectedKeys().hasAny([
          'role', 'criadoPor', 'administradorId', 'supervisorId', 'bloqueado', 'ativo', 'condominioId'
        ]);

      // Atualizar por hierarquia (admin/master gerencia seus subordinados)
      allow update: if isAuthenticated() && isActiveUser() && isAdminOrAbove() &&
        isInHierarchyOf(userId) &&
        // Ninguém pode promover a master
        request.resource.data.role != 'master' &&
        // Admin não pode promover a admin (só master)
        (getRole() == 'master' || request.resource.data.role != 'administrador');

      // Deletar: só master pode deletar; admin pode deletar seus subordinados
      allow delete: if isAuthenticated() && isActiveUser() && (
        isMaster() ||
        (getRole() == 'administrador' && isInHierarchyOf(userId))
      );
    }

    // ╔══════════════════════════════════════════════════════════════╗
    // ║  COLLECTION: condominios                                    ║
    // ╚══════════════════════════════════════════════════════════════╝

    match /condominios/{condominioId} {
      // Ler: master vê todos; admin/sup/func vê apenas os que tem acesso
      allow read: if isAuthenticated() && isActiveUser() && hasCondominioAccess(condominioId);

      // Criar: admin+ cria, e registra criadoPor com seu uid
      allow create: if isAuthenticated() && isActiveUser() && isAdminOrAbove() &&
        request.resource.data.criadoPor == request.auth.uid &&
        request.resource.data.nome is string &&
        request.resource.data.ativo == true;

      // Atualizar: só quem criou ou master
      allow update: if isAuthenticated() && isActiveUser() && (
        isMaster() || resource.data.criadoPor == request.auth.uid
      );

      // Deletar: só master ou quem criou
      allow delete: if isAuthenticated() && isActiveUser() && (
        isMaster() || resource.data.criadoPor == request.auth.uid
      );
    }

    // ╔══════════════════════════════════════════════════════════════╗
    // ║  COLLECTIONS COM condominioId (isolamento por condomínio)   ║
    // ║  ordensServico, checklists, inspecoes, tarefas, escalas,    ║
    // ║  materiais, vistorias, reportes, vencimentos, moradores,    ║
    // ║  comunicados, quadroAtividades, roteiros, qrcodes           ║
    // ╚══════════════════════════════════════════════════════════════╝

    // Função genérica: documento com campo condominioId
    match /ordensServico/{docId} {
      allow read: if isAuthenticated() && isActiveUser() && hasCondominioAccess(resource.data.condominioId);
      allow create: if isAuthenticated() && isActiveUser() && isSupervisorOrAbove() &&
        hasCondominioAccess(request.resource.data.condominioId) &&
        request.resource.data.criadoPor == request.auth.uid;
      allow update: if isAuthenticated() && isActiveUser() && hasCondominioAccess(resource.data.condominioId);
      allow delete: if isAuthenticated() && isActiveUser() && isAdminOrAbove() && hasCondominioAccess(resource.data.condominioId);
    }

    match /checklists/{docId} {
      allow read: if isAuthenticated() && isActiveUser() && hasCondominioAccess(resource.data.condominioId);
      allow create: if isAuthenticated() && isActiveUser() && isSupervisorOrAbove() &&
        hasCondominioAccess(request.resource.data.condominioId);
      allow update: if isAuthenticated() && isActiveUser() && hasCondominioAccess(resource.data.condominioId);
      allow delete: if isAuthenticated() && isActiveUser() && isAdminOrAbove() && hasCondominioAccess(resource.data.condominioId);
    }

    match /inspecoes/{docId} {
      allow read: if isAuthenticated() && isActiveUser() && hasCondominioAccess(resource.data.condominioId);
      allow create: if isAuthenticated() && isActiveUser() && isSupervisorOrAbove() &&
        hasCondominioAccess(request.resource.data.condominioId);
      allow update: if isAuthenticated() && isActiveUser() && isSupervisorOrAbove() && hasCondominioAccess(resource.data.condominioId);
      allow delete: if isAuthenticated() && isActiveUser() && isAdminOrAbove() && hasCondominioAccess(resource.data.condominioId);
    }

    match /tarefas/{docId} {
      allow read: if isAuthenticated() && isActiveUser() && hasCondominioAccess(resource.data.condominioId);
      allow create: if isAuthenticated() && isActiveUser() && isSupervisorOrAbove() &&
        hasCondominioAccess(request.resource.data.condominioId);
      allow update: if isAuthenticated() && isActiveUser() && hasCondominioAccess(resource.data.condominioId);
      allow delete: if isAuthenticated() && isActiveUser() && isAdminOrAbove() && hasCondominioAccess(resource.data.condominioId);
    }

    match /escalas/{docId} {
      allow read: if isAuthenticated() && isActiveUser() && hasCondominioAccess(resource.data.condominioId);
      allow create: if isAuthenticated() && isActiveUser() && isSupervisorOrAbove() &&
        hasCondominioAccess(request.resource.data.condominioId);
      allow update: if isAuthenticated() && isActiveUser() && isSupervisorOrAbove() && hasCondominioAccess(resource.data.condominioId);
      allow delete: if isAuthenticated() && isActiveUser() && isAdminOrAbove() && hasCondominioAccess(resource.data.condominioId);
    }

    match /materiais/{docId} {
      allow read: if isAuthenticated() && isActiveUser() && hasCondominioAccess(resource.data.condominioId);
      allow create: if isAuthenticated() && isActiveUser() && hasCondominioAccess(request.resource.data.condominioId);
      allow update: if isAuthenticated() && isActiveUser() && hasCondominioAccess(resource.data.condominioId);
      allow delete: if isAuthenticated() && isActiveUser() && isAdminOrAbove() && hasCondominioAccess(resource.data.condominioId);
    }

    match /materiaisMovimentacoes/{docId} {
      allow read: if isAuthenticated() && isActiveUser() && hasCondominioAccess(resource.data.condominioId);
      allow create: if isAuthenticated() && isActiveUser() && hasCondominioAccess(request.resource.data.condominioId);
      allow update: if isAuthenticated() && isActiveUser() && isSupervisorOrAbove() && hasCondominioAccess(resource.data.condominioId);
      allow delete: if isAuthenticated() && isActiveUser() && isAdminOrAbove() && hasCondominioAccess(resource.data.condominioId);
    }

    match /vistorias/{docId} {
      allow read: if isAuthenticated() && isActiveUser() && hasCondominioAccess(resource.data.condominioId);
      allow create: if isAuthenticated() && isActiveUser() && hasCondominioAccess(request.resource.data.condominioId);
      allow update: if isAuthenticated() && isActiveUser() && hasCondominioAccess(resource.data.condominioId);
      allow delete: if isAuthenticated() && isActiveUser() && isAdminOrAbove() && hasCondominioAccess(resource.data.condominioId);
    }

    match /reportes/{docId} {
      allow read: if isAuthenticated() && isActiveUser() && hasCondominioAccess(resource.data.condominioId);
      allow create: if isAuthenticated() && isActiveUser() && hasCondominioAccess(request.resource.data.condominioId);
      allow update: if isAuthenticated() && isActiveUser() && hasCondominioAccess(resource.data.condominioId);
      allow delete: if isAuthenticated() && isActiveUser() && isAdminOrAbove() && hasCondominioAccess(resource.data.condominioId);
    }

    match /vencimentos/{docId} {
      allow read: if isAuthenticated() && isActiveUser() && hasCondominioAccess(resource.data.condominioId);
      allow create: if isAuthenticated() && isActiveUser() && isSupervisorOrAbove() &&
        hasCondominioAccess(request.resource.data.condominioId);
      allow update: if isAuthenticated() && isActiveUser() && isSupervisorOrAbove() && hasCondominioAccess(resource.data.condominioId);
      allow delete: if isAuthenticated() && isActiveUser() && isAdminOrAbove() && hasCondominioAccess(resource.data.condominioId);
    }

    match /moradores/{docId} {
      allow read: if isAuthenticated() && isActiveUser() && hasCondominioAccess(resource.data.condominioId);
      allow create: if isAuthenticated() && isActiveUser() && isSupervisorOrAbove() &&
        hasCondominioAccess(request.resource.data.condominioId);
      allow update: if isAuthenticated() && isActiveUser() && isSupervisorOrAbove() && hasCondominioAccess(resource.data.condominioId);
      allow delete: if isAuthenticated() && isActiveUser() && isAdminOrAbove() && hasCondominioAccess(resource.data.condominioId);
    }

    match /comunicados/{docId} {
      allow read: if isAuthenticated() && isActiveUser() && hasCondominioAccess(resource.data.condominioId);
      allow create: if isAuthenticated() && isActiveUser() && isSupervisorOrAbove() &&
        hasCondominioAccess(request.resource.data.condominioId);
      allow update: if isAuthenticated() && isActiveUser() && isSupervisorOrAbove() && hasCondominioAccess(resource.data.condominioId);
      allow delete: if isAuthenticated() && isActiveUser() && isAdminOrAbove() && hasCondominioAccess(resource.data.condominioId);
    }

    match /quadroAtividades/{docId} {
      allow read: if isAuthenticated() && isActiveUser() && hasCondominioAccess(resource.data.condominioId);
      allow create: if isAuthenticated() && isActiveUser() && hasCondominioAccess(request.resource.data.condominioId);
      allow update: if isAuthenticated() && isActiveUser() && hasCondominioAccess(resource.data.condominioId);
      allow delete: if isAuthenticated() && isActiveUser() && isAdminOrAbove() && hasCondominioAccess(resource.data.condominioId);
    }

    match /roteiros/{docId} {
      allow read: if isAuthenticated() && isActiveUser() && hasCondominioAccess(resource.data.condominioId);
      allow create: if isAuthenticated() && isActiveUser() && isSupervisorOrAbove() &&
        hasCondominioAccess(request.resource.data.condominioId);
      allow update: if isAuthenticated() && isActiveUser() && hasCondominioAccess(resource.data.condominioId);
      allow delete: if isAuthenticated() && isActiveUser() && isAdminOrAbove() && hasCondominioAccess(resource.data.condominioId);
    }

    match /qrcodes/{docId} {
      allow read: if isAuthenticated() && isActiveUser() && hasCondominioAccess(resource.data.condominioId);
      allow create: if isAuthenticated() && isActiveUser() && isSupervisorOrAbove() &&
        hasCondominioAccess(request.resource.data.condominioId);
      allow update: if isAuthenticated() && isActiveUser() && isSupervisorOrAbove() && hasCondominioAccess(resource.data.condominioId);
      allow delete: if isAuthenticated() && isActiveUser() && isAdminOrAbove() && hasCondominioAccess(resource.data.condominioId);
    }

    // ╔══════════════════════════════════════════════════════════════╗
    // ║  COLLECTION: geolocalizacao (dados sensíveis de GPS)        ║
    // ╚══════════════════════════════════════════════════════════════╝

    match /geolocalizacao/{docId} {
      // Funcionário vê só a própria localização; supervisor+ vê subordinados
      allow read: if isAuthenticated() && isActiveUser() && (
        resource.data.userId == request.auth.uid ||
        isSupervisorOrAbove()
      );
      // Só o próprio funcionário pode registrar sua localização
      allow create: if isAuthenticated() && isActiveUser() &&
        request.resource.data.userId == request.auth.uid;
      allow update: if isAuthenticated() && isActiveUser() &&
        resource.data.userId == request.auth.uid;
      allow delete: if false; // Logs de geo nunca são apagados
    }

    // ╔══════════════════════════════════════════════════════════════╗
    // ║  COLLECTION: controlePonto (controle de presença)           ║
    // ╚══════════════════════════════════════════════════════════════╝

    match /controlePonto/{docId} {
      allow read: if isAuthenticated() && isActiveUser() && (
        resource.data.userId == request.auth.uid ||
        isSupervisorOrAbove()
      );
      allow create: if isAuthenticated() && isActiveUser() &&
        request.resource.data.userId == request.auth.uid;
      allow update: if isAuthenticated() && isActiveUser() &&
        resource.data.userId == request.auth.uid;
      allow delete: if false; // Registros de ponto nunca são apagados
    }

    // ╔══════════════════════════════════════════════════════════════╗
    // ║  COLLECTION: permissoesFuncoes (configuração de permissões) ║
    // ╚══════════════════════════════════════════════════════════════╝

    match /permissoesFuncoes/{docId} {
      allow read: if isAuthenticated() && isActiveUser();
      allow write: if isAuthenticated() && isActiveUser() && isAdminOrAbove();
    }

    // ╔══════════════════════════════════════════════════════════════╗
    // ║  COLLECTION: tema (configuração de tema)                    ║
    // ╚══════════════════════════════════════════════════════════════╝

    match /tema/{docId} {
      allow read: if isAuthenticated();
      allow write: if isAuthenticated() && isActiveUser() && isAdminOrAbove();
    }

    // ╔══════════════════════════════════════════════════════════════╗
    // ║  REGRA PADRÃO: negar tudo que não foi coberto acima         ║
    // ╚══════════════════════════════════════════════════════════════╝
    // Nenhuma regra wildcard - collections não definidas acima são NEGADAS
  }
}
